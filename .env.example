# OpenMobile — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then export (or use python-dotenv):
#   source .env   (bash/zsh)

# ── Telegram Credentials (required for --headless mode) ─────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org → "API Development Tools"
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
# Get BOT_TOKEN from @BotFather on Telegram
TG_BOT_TOKEN=your_bot_token_here

# ── Security: Authorized Users ──────────────────────────────────────────────────
# Comma-separated Telegram user IDs (get yours from @userinfobot)
# Leave empty to allow ALL users (not recommended)
ALLOWED_USERS=123456789,987654321

# ── Ollama Server ────────────────────────────────────────────────────────────────
# URL of your Ollama server (default: localhost)
# If Ollama runs on a networked PC, set to: http://192.168.x.x:11434
OLLAMA_URL=http://localhost:11434

# ── Models ───────────────────────────────────────────────────────────────────────
# Planner: lightweight reasoning model (~0.5B params)
# Pull with: ollama pull qwen2.5:0.5b
PLANNER_MODEL=qwen2.5:0.5b

# Vision Actor: lightweight vision model (~1.6B params)
# Pull with: ollama pull moondream
VISION_MODEL=moondream

# ── Agent Tuning ─────────────────────────────────────────────────────────────────
# Maximum steps per goal before giving up
MAX_STEPS=15
# Delay between steps in seconds (gives UI time to settle)
STEP_DELAY=2.0
# Number of retries per step on failure
RETRY_LIMIT=2
# Confidence threshold: below this, Vision Actor coords override Planner coords
CONFIDENCE_THRESHOLD=0.70
# How many past steps to include in prompts (rolling window)
MEMORY_WINDOW=5

# ── WhatsApp Polling ──────────────────────────────────────────────────────────────
# How often to check WhatsApp notifications (seconds)
WA_POLL_INTERVAL=5

# ── Debug ─────────────────────────────────────────────────────────────────────────
# Set to 1 to enable verbose debug logging
DEBUG=0
